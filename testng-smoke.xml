<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Smoke Suite" parallel="false" verbose="1">

    <listeners>
        <listener class-name="api.utilities.Listeners"/>
    </listeners>

    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="api.test.UserTest"/>
            <class name="api.test.StoreTest"/>
        </classes>
    </test>
</suite>
